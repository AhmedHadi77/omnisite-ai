{
  "name": "omnisite-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm run db:generate && npm --workspace apps/web run build",
    "build:prod": "npm run db:generate:prod && npm --workspace apps/web run build",
    "deploy:vercel": "vercel --prod",
    "typecheck": "npm --workspaces run typecheck",
    "db:generate": "prisma generate",
    "db:generate:prod": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:init": "node prisma/init-local-db.js",
    "db:seed": "prisma db seed",
    "db:reset": "npm run db:init && npm run db:seed",
    "db:push:prod": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:seed:prod": "npm run db:generate:prod && prisma db seed --schema prisma/schema.postgres.prisma"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "typescript": "latest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
